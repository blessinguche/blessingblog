# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (optional for local — without these, Blessing uses data/*.json + local auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local writer auth (used when Supabase is not configured)
WRITER_PASSWORD=blessing
WRITER_SESSION_SECRET=change-me-to-a-long-random-string

# Contact form — recipient is server-only (never shown on the site)
CONTACT_TO_EMAIL=blesinucheuche7@gmail.com
RESEND_API_KEY=
# Optional verified sender once you have a domain on Resend:
# CONTACT_FROM_EMAIL=Blessing <hello@yourdomain.com>
