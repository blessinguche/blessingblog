# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Writer login (REQUIRED in production / Vercel)
WRITER_PASSWORD=password
WRITER_SESSION_SECRET=change-me-to-a-long-random-string
# Optional legacy field
WRITER_EMAIL=

# Supabase — public (safe in browser / Vercel)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or use the new publishable key name (same value as anon):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase — server only (Vercel env, never commit)
SUPABASE_SECRET_KEY=

# Contact form — recipient is server-only (never shown on the site)
CONTACT_TO_EMAIL=
RESEND_API_KEY=
# CONTACT_FROM_EMAIL=Your Name <hello@yourdomain.com>

# --- Vercel production checklist ---
# Set ALL of these in Vercel → Project → Settings → Environment Variables
# (Production + Preview if you use previews):
#
#   NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
#   WRITER_PASSWORD=...
#   WRITER_SESSION_SECRET=...   (long random string)
#   NEXT_PUBLIC_SUPABASE_URL=...
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=...
#   SUPABASE_SECRET_KEY=...
#   CONTACT_TO_EMAIL=...
#   RESEND_API_KEY=...
#   CONTACT_FROM_EMAIL=Blessing <onboarding@resend.dev>
#
# Then run supabase/schema.sql in the Supabase SQL editor
# (creates posts, subscribers, gallery_images, and the public "media" storage bucket).
# Redeploy after setting env vars.
